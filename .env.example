# Database
DATABASE_URL=postgresql://bowling:password@localhost:5432/bowling_db
DATABASE_POOL_SIZE=10

# Redis cache
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=300

# API keys
ANTHROPIC_API_KEY=sk-ant-...
METRICS_API_KEY=...

# Service ports
JAVA_API_PORT=8080
PYTHON_API_PORT=8000
SCORING_SERVICE_PORT=3000

# Feature flags
ENABLE_LLM_ANALYSIS=false
ENABLE_METRICS=true
LOG_LEVEL=info
